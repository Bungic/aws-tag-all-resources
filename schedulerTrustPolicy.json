{
    "Version": "2012-10-17",
    "Statement": [
        {
            "Sid": "SchedulerAssume",
            "Effect": "Allow",
            "Principal": {
                "Service": "scheduler.amazonaws.com"
            },
            "Action": "sts:AssumeRole",
            "Condition": {
                "StringEquals": {
                    "aws:SourceAccount": "__ACCOUNT_ID__"
                }
            }
        }
    ]
}
